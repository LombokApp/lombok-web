#!/usr/bin/env bash
set -euo pipefail

export DOCKER_CLI_HINTS=false

PROJECT_ID_FILE=".lombok-project-id"

# Word lists for friendly project names like `lombok-dev-amber-otter`.
DX_ADJECTIVES=(amber bold brave calm cosy daring dapper eager earthy fluffy
  frosty gentle golden happy ivory jolly keen lucky merry nimble opal plucky
  quiet ruby silver sunny tidy umber vivid witty zesty)
DX_NOUNS=(badger condor crane dolphin elk falcon fox gull hare heron ibis jay
  koala lion lynx mole newt otter owl panda puffin quail raven salmon stoat
  tiger urchin viper wren yak zebra)

# Resolve dev project ID + build ID.
#   - Project ID: stable per-checkout, persisted in .lombok-project-id (gitignored).
#     Used as COMPOSE_PROJECT_NAME so containers/volumes survive commits.
#   - Build ID: <project>-<branch>-<hash>, recomputed every invocation. Surfaced
#     by /api/v1/public/build-id and /build-id; never used as the compose name.
# Pass "generate" to create the project ID if missing (only `up` should do this).
resolve_build_id() {
  local mode="${1:-require}"
  local project=""
  if [ -f "$PROJECT_ID_FILE" ]; then
    project=$(tr -d '[:space:]' < "$PROJECT_ID_FILE")
  fi
  if [ -z "$project" ]; then
    if [ "$mode" = "generate" ]; then
      local adj noun
      adj=${DX_ADJECTIVES[$((RANDOM % ${#DX_ADJECTIVES[@]}))]}
      noun=${DX_NOUNS[$((RANDOM % ${#DX_NOUNS[@]}))]}
      project="lombok-dev-${adj}-${noun}"
      printf '%s\n' "$project" > "$PROJECT_ID_FILE"
      echo "Generated dev project ID: $project (saved to $PROJECT_ID_FILE)" >&2
    else
      echo "No $PROJECT_ID_FILE found. Run './dx up' first to generate one." >&2
      exit 1
    fi
  fi
  local hash="nogit" branch="" branch_part=""
  if command -v git >/dev/null 2>&1; then
    hash=$(git rev-parse --short HEAD 2>/dev/null || echo "nogit")
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
  fi
  if [ -n "$branch" ] && [ "$branch" != "HEAD" ]; then
    # Compose project names allow only [a-z0-9_-]; fold to that and trim.
    branch_part=$(printf '%s' "$branch" \
      | tr '[:upper:]' '[:lower:]' \
      | sed -e 's/[^a-z0-9_-]/-/g' -e 's/--*/-/g' -e 's/^-//' -e 's/-$//' \
      | cut -c1-40)
  fi
  if [ -n "$branch_part" ]; then
    export LOMBOK_BUILD_ID="${project}-${branch_part}-${hash}"
  else
    export LOMBOK_BUILD_ID="${project}-${hash}"
  fi
  export COMPOSE_PROJECT_NAME="$project"

  # In a git worktree, `.git` is a file pointing at an absolute host path
  # (e.g., /Users/.../.git/worktrees/<name>). For `git` inside the container
  # to resolve refs, we bind-mount the host's git common dir at the same
  # absolute path. Compose volume defaults to /dev/null when unset/empty.
  if command -v git >/dev/null 2>&1; then
    local git_common_dir resolved=""
    git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null || true)
    if [ -n "$git_common_dir" ] && [ -d "$git_common_dir" ]; then
      resolved=$(cd "$git_common_dir" 2>/dev/null && pwd -P || true)
    fi
    if [ -n "$resolved" ]; then
      export HOST_GIT_COMMON_DIR="$resolved"
    fi
  fi
}

require_container() {
  resolve_build_id
  local cid
  cid=$(docker compose ps -q api 2>/dev/null || true)
  if [ -z "$cid" ] || ! docker container inspect -f '{{.State.Running}}' "$cid" 2>/dev/null | grep -q true; then
    echo "No running api container for project '$COMPOSE_PROJECT_NAME'. Start it with: ./dx up" >&2
    exit 1
  fi
}

# Use -it flags only when stdin is a terminal.
# Run as user bun via su-exec because the container drops CAP_KILL,
# so root cannot signal bun-owned processes.
if [ -t 0 ]; then
  DOCKER_EXEC="docker compose exec api su-exec bun"
else
  DOCKER_EXEC="docker compose exec -T api su-exec bun"
fi

DOCKER_EXEC_NOTTY="docker compose exec -T api su-exec bun"

usage() {
  cat <<'HELP'
Usage: ./dx <command>

Commands:
  check all            Run prettier, tsc, and eslint across all packages
  check eslint         Run eslint across all packages
  check prettier       Run prettier across all packages
  fix prettier         Fix prettier issues across all packages
  check tsc            Run tsc across all packages
  reload api           Reload the NestJS API (triggers bun watch reload)
  restart api          Restart the NestJS API (triggers restart of the app, which loads new env)
  restart ui           Restart the Vite frontend dev server
  restart bridge       Restart the docker bridge server
  db seed              Seed the database with dev data
  db reset             Drop all tables and re-migrate
  db reset:seed        Drop all tables, re-migrate, and re-seed
  db purge             Drop all tables and schemas
  db migrate           Run pending database migrations
  db migrate:new       Generate a new migration
  unit <package>       Run unit tests for a package
  e2e api              Run API end-to-end tests
  e2e ui               Run UI end-to-end tests
  e2e api "<glob>"     Run API end-to-end tests by glob
  e2e down             Stop the e2e environment (docker compose down)
  e2e kill             Force-kill the e2e environment (docker compose kill)
  e2e purge            Tear down and remove e2e containers, volumes, and images
  up [-d]              Start the dev environment (-d for detached/daemon mode)
  down                 Stop the dev environment (docker compose down)
  kill                 Force-kill the dev environment (docker compose kill)
  purge all            Tear down and remove all volumes, images, and orphans
  purge db             Tear down and remove the Postgres data volume
  purge minio          Tear down and remove the MinIO data volume
  generate openapi     Generate the OpenAPI spec
  generate metadata    Generate NestJS metadata
  release standalone <version>   Build the standalone release image (e.g. 1.2.1-beta-rc3)
  release separate-db <version>  Build the separate-db release image (e.g. 1.2.1-beta-rc3)
  install              Force-reinstall dependencies on host and in container
  exec <cmd...>        Run an arbitrary command inside the container
  logs                 Tail the container logs
  shell                Open a shell inside the container
  help                 Show this help message
HELP
}

case "${1:-help}" in
  check)
    case "${2:-}" in
      all)
        sh ./cmd/dev-check-all.sh
        ;;
      eslint)
        sh ./cmd/dev-eslint-all.sh
        ;;
      prettier)
        sh ./cmd/dev-prettier-all.sh
        ;;
      tsc)
        sh ./cmd/dev-tsc-all.sh
        ;;
      *)
        echo "Usage: ./dx check <all|eslint|prettier|tsc>" >&2
        exit 1
        ;;
    esac
    ;;
  fix)
    case "${2:-}" in
      prettier)
        sh ./cmd/dev-prettier-fix-all.sh
        ;;
      eslint)
        sh ./cmd/dev-eslint-fix-all.sh
        ;;
      *)
        echo "Usage: ./dx fix <prettier|eslint>" >&2
        exit 1
        ;;
    esac
    ;;
  restart)
    require_container
    case "${2:-}" in
      api)
        $DOCKER_EXEC bun --cwd packages/api restart
        ;;
      ui)
        $DOCKER_EXEC_NOTTY sh /usr/src/app/packages/api/cmd/restart-ui.sh
        ;;
      bridge)
        $DOCKER_EXEC pkill -f 'bun run.*/docker-bridge/src/index.ts' || true
        echo "Sent kill signal to docker-bridge. The API service will restart it automatically."
        ;;
      *)
        echo "Usage: ./dx restart (api|ui|bridge)" >&2
        exit 1
        ;;
    esac
    ;;
  reload)
    require_container
    case "${2:-}" in
      api)
        $DOCKER_EXEC bun --cwd packages/api reload
        ;;
      *)
        echo "Usage: ./dx reload <api|ui>" >&2
        exit 1
        ;;
    esac
    ;;
  db)
    case "${2:-}" in
      migrate:new)
        bun --cwd packages/api db:migrate:new
        ;;
      seed)
        require_container
        $DOCKER_EXEC bun --cwd packages/api db:seed && ./dx reload api
        ;;
      reset)
        require_container
        $DOCKER_EXEC bun --cwd packages/api db:reset && ./dx reload api
        ;;
      reset:seed)
        require_container
        $DOCKER_EXEC bun --cwd packages/api db:reset && ./dx db seed
        ;;
      purge)
        require_container
        $DOCKER_EXEC bun --cwd packages/api db:clean
        ;;
      migrate)
        require_container
        $DOCKER_EXEC bun --cwd packages/api db:migrate
        ;;
      *)
        echo "Usage: ./dx db <seed|reset|migrate|migrate:new>" >&2
        exit 1
        ;;
    esac
    ;;
  unit)
    require_container
    pkg="${2:-}"
    if [ -z "$pkg" ]; then
      echo "Usage: ./dx unit <package>" >&2
      exit 1
    fi
    if [ ! -d "packages/$pkg" ]; then
      echo "Unknown package: $pkg" >&2
      echo "Available packages: $(ls -m packages/)" >&2
      exit 1
    fi
    if ! grep -q '"test:unit"' "packages/$pkg/package.json" 2>/dev/null; then
      echo "Package '$pkg' does not have a test:unit script" >&2
      exit 1
    fi
    $DOCKER_EXEC bun --cwd "packages/$pkg" test:unit
    ;;
  e2e)
    case "${2:-}" in
      api)
        bun --cwd packages/api e2e:api ${3:-}
        ;;
      ui)
        bun --cwd packages/api e2e:ui ${3:-}
        ;;
      core-worker)
        bun --cwd packages/core-worker e2e
        ;;
      down)
        docker compose -f docker-compose.test.yml down
        ;;
      kill)
        docker compose -f docker-compose.test.yml kill
        ;;
      purge)
        docker compose -f docker-compose.test.yml down --volumes --rmi local --remove-orphans
        docker image rm -f lomboke2e >/dev/null 2>&1 || true
        ;;
      *)
        echo "Usage: ./dx e2e <api|ui|down|kill|purge>" >&2
        exit 1
        ;;
    esac
    ;;
  integration)
    case "${2:-}" in
      core-worker)
        bun --cwd packages/core-worker test:integration
        ;;
      *)
        echo "Usage: ./dx integration core-worker" >&2
        exit 1
        ;;
    esac
    ;;

  up)
    resolve_build_id generate
    if [ "${2:-}" = "-d" ]; then
      docker compose up -d
    else
      docker compose up
    fi
    ;;
  up:rebuild)
    resolve_build_id generate
    docker compose up --build
    ;;
  down)
    resolve_build_id
    docker compose down
    ;;
  kill)
    resolve_build_id
    docker compose kill
    ;;
  purge)
    resolve_build_id
    case "${2:-}" in
      all)
        docker compose down --volumes --rmi local --remove-orphans
        ;;
      db)
        docker compose down && docker volume rm "${COMPOSE_PROJECT_NAME}_pgdata"
        ;;
      minio)
        docker compose down && docker volume rm "${COMPOSE_PROJECT_NAME}_miniodata"
        ;;
      *)
        echo "Usage: ./dx purge <all|db|minio>" >&2
        exit 1
        ;;
    esac
    ;;
  generate)
    require_container
    case "${2:-}" in
      openapi)
        bun --cwd packages/api generate:openapi
        ;;
      metadata)
        $DOCKER_EXEC bun --cwd packages/api generate:metadata
        ;;
      *)
        echo "Usage: ./dx generate <openapi|metadata>" >&2
        exit 1
        ;;
    esac
    ;;
  release)
    version="${3:-}"
    if [ -z "$version" ]; then
      echo "Usage: ./dx release <standalone|separate-db> <version>   (e.g. ./dx release standalone 1.2.1-beta-rc3)" >&2
      exit 1
    fi
    case "${2:-}" in
      standalone)
        (cd ./deploy && sh ./build-standalone.sh "$version")
        ;;
      separate-db)
        (cd ./deploy && sh ./build-separate-db.sh "$version")
        ;;
      *)
        echo "Usage: ./dx release <standalone|separate-db> <version>" >&2
        exit 1
        ;;
    esac
    ;;
  install)
    bun install --force && ./dx exec bun install --force
    ;;
  exec)
    require_container
    shift
    $DOCKER_EXEC "$@"
    ;;
  logs)
    require_container
    docker compose logs -f api
    ;;
  shell)
    require_container
    $DOCKER_EXEC sh
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
