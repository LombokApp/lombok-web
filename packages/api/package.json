{
  "name": "@lombokapp/api",
  "private": true,
  "scripts": {
    "start": "bun dist/src/main.js",
    "dev": "bun --watch src/main.ts",
    "build": "rm -rf ./dist && NODE_ENV=production bun run script/build.ts",
    "test:unit:watch": "bun run test/unit.run.ts --watch",
    "test:unit": "bun run test/unit.run.ts",
    "lint:check": "eslint",
    "lint:fix": "eslint --fix",
    "tsc:check": "tsc --noEmit",
    "db:migrate": "bun ./script/db-migrate-up.ts",
    "db:migrate:new": "bunx drizzle-kit generate --config ./src/orm/drizzle.config.ts",
    "db:migrate:check": "bunx drizzle-kit check:pg --config ./src/orm/drizzle.config.ts",
    "db:migrate:drop": "bunx drizzle-kit drop --config ./src/orm/drizzle.config.ts",
    "db:reset": "bun ./script/db-clean.ts && bun db:migrate && bun db:seed",
    "db:clean": "bun ./script/db-clean.ts",
    "db:seed": "bun ./script/db-seed.ts",
    "ci:e2e:ui": "bun e2e:build && docker run --rm --privileged lomboke2e -- ui",
    "ci:e2e:api": "bun e2e:build && docker run --rm --privileged lomboke2e -- api",
    "e2e:build": "docker build -f ../../docker/app.Dockerfile --target test -t lomboke2e ../../",
    "e2e:ui": "bun install && bun --cwd ../ui build && docker compose -f ../../docker-compose.test.yml run --rm lomboke2e -- ui",
    "e2e:api": "bun install && docker compose -f ../../docker-compose.test.yml run --rm lomboke2e -- api",
    "e2e:clean": "docker compose -f ../../docker-compose.test.yml kill && docker image rm -f lombok-web-lomboke2e",
    "restart": "bun ./script/dev-restart.ts",
    "reload": "bun ./script/dev-reload.ts",
    "enableapps": "bun ./script/dev-enable-apps.ts",
    "reload:clean": "bun db:clean && bun reload",
    "generate:metadata": "bun script/generate-metadata.ts",
    "generate:openapi": "bun generate:metadata && ./cmd/generate-openapi-spec.sh",
    "prettier:check": "prettier --check \"./**/*.(ts|tsx)\"",
    "prettier:fix": "prettier --write \"./**/*.(ts|tsx)\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.985.0",
    "@heyputer/kv.js": "0.2.1",
    "@lombokapp/core-worker": "workspace:*",
    "@lombokapp/types": "workspace:*",
    "@lombokapp/utils": "workspace:*",
    "@lombokapp/worker-utils": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@nestjs/common": "11.1.13",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.13",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.13",
    "@nestjs/platform-socket.io": "11.1.13",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/websockets": "11.1.13",
    "aws4": "1.13.2",
    "cron": "4.4.0",
    "dockerode": "catalog:",
    "drizzle-orm": "catalog:",
    "express": "5.2.1",
    "i18next": "25.8.4",
    "jexpr": "catalog:",
    "jsonwebtoken": "9.0.3",
    "mime": "catalog:",
    "nestjs-zod": "5.1.1",
    "nodemailer": "catalog:",
    "openapi-fetch": "catalog:",
    "pg": "catalog:",
    "resend": "catalog:",
    "rxjs": "7.8.2",
    "socket.io": "catalog:",
    "utility-types": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.13",
    "@playwright/test": "1.58.2",
    "@stylistic/eslint-plugin": "catalog:",
    "@types/aws4": "1.11.6",
    "@types/bun": "catalog:",
    "@types/dockerode": "catalog:",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/nodemailer": "catalog:",
    "@types/pg": "catalog:",
    "@types/supertest": "6.0.3",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-eslint-comments": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-promise": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "globals": "catalog:",
    "jiti": "catalog:",
    "openapi-typescript": "7.12.0",
    "prettier": "catalog:",
    "socket.io-client": "catalog:",
    "supertest": "7.2.2",
    "tsconfig-paths": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
