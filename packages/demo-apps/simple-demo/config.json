{
  "description": "The demo app.",
  "slug": "demo",
  "label": "Demo App",
  "icon": {
    "source": "custom",
    "format": "png",
    "rendering": "original",
    "assets": [
      {
        "path": "assets/logo-light@2x.png",
        "scale": 2,
        "appearance": "light"
      },
      {
        "path": "assets/logo-dark@2x.png",
        "scale": 2,
        "appearance": "dark"
      }
    ]
  },
  "subscribedCoreEvents": [
    "core:object_added",
    "core:object_removed",
    "core:object_updated"
  ],
  "triggers": [
    {
      "kind": "event",
      "eventIdentifier": "core:object_added",
      "taskIdentifier": "demo_object_added_worker_task",
      "onComplete": [
        {
          "taskIdentifier": "demo_worker_task_on_complete",
          "dataTemplate": {
            "success": {
              "taskError": "{{task.error}}"
            }
          }
        }
      ]
    },
    {
      "kind": "schedule",
      "triggerKey": "hourly_job",
      "config": {
        "kind": "interval",
        "interval": 1,
        "unit": "hours"
      },
      "taskIdentifier": "demo_scheduled_worker_task"
    },
    {
      "kind": "schedule",
      "triggerKey": "weekday_morning_job",
      "config": {
        "kind": "cron",
        "expression": "0 9 * * 1-5",
        "timezone": "UTC"
      },
      "taskIdentifier": "demo_scheduled_worker_task"
    }
  ],
  "tasks": [
    {
      "identifier": "demo_worker_task_on_complete",
      "label": "On Complete Handler",
      "description": "Is run as a completion handler for another task.",
      "handler": {
        "type": "runtime",
        "identifier": "demo_on_complete_worker"
      }
    },
    {
      "identifier": "demo_object_added_worker_task",
      "label": "Demo Object Added Worker",
      "description": "A task that runs for every newly added object.",
      "handler": {
        "type": "runtime",
        "identifier": "demo_object_added_worker"
      }
    },
    {
      "identifier": "demo_scheduled_worker_task",
      "label": "Demo Scheduled Worker",
      "description": "A task that runs in response to a schedule event.",
      "handler": {
        "type": "runtime",
        "identifier": "demo_scheduled_worker"
      }
    },
    {
      "identifier": "demo_async_task",
      "label": "Demo Async Task",
      "description": "A task that simulates multi-step async work and emits progress updates.",
      "handler": {
        "type": "runtime",
        "identifier": "demo_async_worker"
      }
    }
  ],
  "runtimeWorkers": {
    "demo_object_added_worker": {
      "entrypoint": "demo_object_added_worker/index.js",
      "description": "Runs for every newly added object.",
      "environmentVariables": {
        "MY_CUSTOM_ENV_VAR": "_some_non_secret_env_var_value_"
      }
    },
    "demo_scheduled_worker": {
      "entrypoint": "demo_scheduled_worker/index.js",
      "description": "Runs in response to a schedule event.",
      "environmentVariables": {
        "MY_CUSTOM_ENV_VAR": "_some_non_secret_env_var_value_"
      }
    },
    "demo_on_complete_worker": {
      "entrypoint": "demo_on_complete_worker/index.js",
      "description": "Runs as a completion handler for another task."
    },
    "demo_api_request_worker": {
      "entrypoint": "demo_api_request_worker/index.js",
      "description": "Is run to service and incoming API request.",
      "environmentVariables": {
        "MY_CUSTOM_ENV_VAR": "_some_non_secret_env_var_value_"
      }
    },
    "demo_async_worker": {
      "entrypoint": "demo_async_worker/index.js",
      "description": "Simulates multi-step async work with progress updates."
    }
  },
  "ui": {
    "enabled": true
  },
  "database": {
    "enabled": true
  },
  "settings": {
    "secretKeyPattern": "^(api_key|secret|token)",
    "user": {
      "type": "object",
      "properties": {
        "api_key": {
          "type": "string",
          "description": "API key for external service"
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 3
        },
        "theme": {
          "type": "string",
          "enum": [
            "light",
            "dark"
          ],
          "default": "light"
        }
      },
      "required": [
        "api_key"
      ]
    },
    "folder": {
      "type": "object",
      "properties": {
        "auto_index": {
          "type": "boolean",
          "default": true
        }
      }
    }
  },
  "contributions": {
    "uiEntrypoints": [
      {
        "path": "/",
        "label": "Landing Page",
        "icon": {
          "source": "custom",
          "format": "png",
          "rendering": "original",
          "assets": [
            {
              "path": "assets/logo-light@2x.png",
              "scale": 2,
              "appearance": "light"
            },
            {
              "path": "assets/logo-dark@2x.png",
              "scale": 2,
              "appearance": "dark"
            }
          ]
        }
      }
    ],
    "folderSidebarViews": [
      {
        "path": "/folders/folder-sidebar",
        "label": "Demo Folder Sidebar View"
      }
    ],
    "objectSidebarViews": [
      {
        "path": "/folders/object-sidebar",
        "label": "Demo Object Sidebar View"
      }
    ],
    "objectDetailViews": [
      {
        "path": "/folders/object-detail",
        "label": "Demo Object View"
      }
    ],
    "folderDetailViews": [],
    "mobile": {
      "queries": {
        "lombok.viewer": {
          "source": "lombok",
          "path": "/viewer"
        },
        "app.demo.greeting": {
          "source": "app",
          "worker": "demo_api_request_worker",
          "path": "/",
          "method": "GET"
        }
      },
      "root": {
        "views": [
          {
            "id": "home",
            "navRoot": true,
            "components": [
              {
                "id": "root",
                "component": "Column",
                "children": [
                  "title",
                  "subtitle",
                  "demos-section",
                  "greeting-from-lombok",
                  "greeting-from-app",
                  "loading-text"
                ]
              },
              {
                "id": "title",
                "component": "Text",
                "text": "Simple Demo",
                "variant": "h3"
              },
              {
                "id": "subtitle",
                "component": "Text",
                "text": "This screen is rendered from a JSON spec declared in the app's config.json.",
                "variant": "caption"
              },
              {
                "id": "greeting-from-lombok",
                "component": "Text",
                "text": {
                  "path": "/viewer/user/username"
                },
                "variant": "h5"
              },
              {
                "id": "greeting-from-app",
                "component": "Text",
                "text": {
                  "path": "/greeting/message"
                },
                "variant": "body"
              },
              {
                "id": "loading-text",
                "component": "Text",
                "text": {
                  "path": "/loading"
                },
                "variant": "caption"
              },
              {
                "id": "demos-section",
                "component": "Section",
                "title": "Demonstrations",
                "dividers": true,
                "children": [
                  "demo-catalog-tile"
                ]
              },
              {
                "id": "demo-catalog-tile",
                "component": "LombokListRow",
                "title": "Component Catalog",
                "subtitle": "Browse every built-in component",
                "background": "plain",
                "icon": {
                  "builtin": "app",
                  "tint": "purple",
                  "style": "soft"
                },
                "action": {
                  "event": {
                    "name": "navigate",
                    "context": {
                      "target": "catalog",
                      "navTitle": "Component Catalog"
                    }
                  }
                }
              }
            ],
            "initialDataModel": {
              "viewer": {
                "user": {
                  "username": ""
                }
              },
              "greeting": {
                "message": ""
              },
              "loading": ""
            },
            "initialQueries": [
              {
                "query": {
                  "name": "lombok.viewer"
                },
                "targetPath": "/viewer",
                "loadingPath": "/loading"
              },
              {
                "query": {
                  "name": "app.demo.greeting"
                },
                "targetPath": "/greeting"
              }
            ],
            "actionMap": {
              "refresh": [
                {
                  "query": {
                    "name": "lombok.viewer"
                  },
                  "targetPath": "/viewer",
                  "loadingPath": "/loading"
                },
                {
                  "query": {
                    "name": "app.demo.greeting"
                  },
                  "targetPath": "/greeting"
                }
              ]
            },
            "refreshable": true
          },
          {
            "id": "catalog",
            "components": [
              {
                "id": "root",
                "component": "Stack",
                "spacing": 20,
                "padding": 20,
                "children": [
                  "h-Heading",
                  "c-Heading",
                  "h-Subtitle",
                  "c-Subtitle",
                  "h-BodyText",
                  "c-BodyText",
                  "h-Caption",
                  "c-Caption",
                  "h-Section",
                  "c-Section",
                  "h-SectionHeader",
                  "c-SectionHeader",
                  "h-MeasuredColumn",
                  "c-MeasuredColumn",
                  "h-Avatar",
                  "c-Avatar",
                  "h-Badge",
                  "c-Badge",
                  "h-HexTint",
                  "c-HexTint",
                  "h-StatusBadge",
                  "c-StatusBadge",
                  "h-MetricCard",
                  "c-MetricCard",
                  "h-Callout",
                  "c-Callout",
                  "h-Sparkline",
                  "c-Sparkline",
                  "h-ListRow",
                  "c-ListRow",
                  "h-NavTile",
                  "c-NavTile",
                  "h-HeaderCard",
                  "c-HeaderCard",
                  "h-KeyValueRow",
                  "c-KeyValueRow",
                  "h-EmptyState",
                  "c-EmptyState",
                  "h-LombokListRow",
                  "c-LombokListRow",
                  "c-LombokListRow2",
